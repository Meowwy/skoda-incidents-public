{
  "version": 1,
  "steps": [
    {
      "id": "user_id",
      "type": "hidden",
      "source": "active_directory"
    },
    {
      "id": "system",
      "type": "select",
      "question": "Jaký systém má výpadek?",
      "options": [
        "ANDON",
        "IMIS",
        "WMS KAKL",
        "WMS MAKL",
        "WMS U6A",
        "WMS U6C",
        "LKW Control x",
        "HOD",
        "iTLS",
        "LOGIS",
        "INEAS-BMA",
        "INEAS-MA"
      ]
    },
    {
      "id": "lkw_purpose",
      "type": "select",
      "question": "K čemu se systém používá?",
      "options": [
        "Závodová ochrana (na bráně)",
        "Interní logistika (PLO)",
        "Něco jiného"
      ],
      "render_if": "system == 'LKW Control x'"
    },
    {
      "id": "lkw_purpose_dead_end",
      "type": "info",
      "question": "Mimo standardní proces",
      "description": "Kontaktujte svého nadřízeného.",
      "render_if": "system == 'LKW Control x' && lkw_purpose == 'Něco jiného'",
      "action": "stop"
    },
    {
      "id": "lkw_device",
      "type": "select",
      "question": "Jaké zařízení používáte?",
      "options": [
        "Telematika",
        "Vlastní mobilní telefon",
        "HDT",
        "Systém LKWc",
        "Syncro Supply Center"
      ],
      "render_if": "system == 'LKW Control x' && lkw_purpose != 'Něco jiného'"
    },
    {
      "id": "lkw_symptom",
      "type": "select",
      "question": "Co přesně nefunguje?",
      "options": [
        "Výpadek telematiky",
        "Nemožnost přihlášení",
        "Výpadek systému",
        "Chyba v rozhraní",
        "Prázdný seznam jízd"
      ],
      "render_if": "system == 'LKW Control x' && lkw_purpose != 'Něco jiného'"
    },
    {
      "id": "diag_tel_operator",
      "type": "boolean",
      "question": "Je hlášený / registrovaný výpadek u operátora?",
      "render_if": "lkw_symptom == 'Výpadek telematiky'",
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Výpadek operátora",
          "resolver_group": "MOBILE PHONES Support SKODA",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Není"
        }
      }
    },
    {
      "id": "diag_tel_data",
      "type": "boolean",
      "question": "Jsou aktivní data?",
      "render_if": "lkw_symptom == 'Výpadek telematiky' && diag_tel_operator == false",
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Chybné nastavení",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Správné nastavení přes help desk"
        }
      }
    },
    {
      "id": "diag_tel_airplane",
      "type": "boolean",
      "question": "Je zapnutý režim letadlo?",
      "render_if": "lkw_symptom == 'Výpadek telematiky' && diag_tel_data == true",
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Chybné nastavení",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Správné nastavení přes help desk"
        }
      }
    },
    {
      "id": "diag_tel_multiple",
      "type": "boolean",
      "question": "Mají další telematiky stejnou závadu?",
      "render_if": "lkw_symptom == 'Výpadek telematiky' && diag_tel_airplane == false",
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Nefunkčnost 1 telematiky",
          "resolver_group": "LOGISTICKE SYSTEMY Support SKODA",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Výměna telematiky"
        }
      },
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Globální výpadek telematiky",
          "resolver_group": "LOGISTICKE SYSTEMY Support SKODA",
          "impact": 2,
          "can_close": "Ne",
          "backup_strategy": "Není známa (krizový stav)"
        }
      }
    },
    {
      "id": "hod_purpose",
      "type": "select",
      "question": "K čemu se HOD používá?",
      "options": [
        "Příjem zboží",
        "Vyskladnění",
        "Inventura",
        "Něco jiného"
      ],
      "render_if": "system == 'HOD'"
    },
    {
      "id": "hod_purpose_dead_end",
      "type": "info",
      "question": "Mimo standardní proces",
      "description": "Kontaktujte svého nadřízeného.",
      "render_if": "system == 'HOD' && hod_purpose == 'Něco jiného'",
      "action": "stop"
    },
    {
      "id": "hod_device",
      "type": "select",
      "question": "Jaké zařízení používáte?",
      "options": [
        "Ruční terminál (HHT)",
        "Tablet",
        "PC stanice"
      ],
      "render_if": "system == 'HOD' && hod_purpose != 'Něco jiného'"
    },
    {
      "id": "hod_symptom",
      "type": "select",
      "question": "Co přesně nefunguje?",
      "options": [
        "Aplikace se nespustí",
        "Chyba při skenování",
        "Ztráta připojení",
        "Nesprávná data"
      ],
      "render_if": "system == 'HOD' && hod_purpose != 'Něco jiného'"
    },
    {
      "id": "diag_hod_wifi",
      "type": "boolean",
      "question": "Je zařízení připojeno k Wi-Fi?",
      "render_if": "hod_symptom == 'Ztráta připojení'",
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Výpadek Wi-Fi připojení",
          "resolver_group": "NETWORK Support SKODA",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Restart zařízení a opětovné připojení k síti"
        }
      }
    },
    {
      "id": "diag_hod_other_devices",
      "type": "boolean",
      "question": "Mají ostatní zařízení stejný problém?",
      "render_if": "hod_symptom == 'Ztráta připojení' && diag_hod_wifi == true",
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Globální výpadek sítě",
          "resolver_group": "NETWORK Support SKODA",
          "impact": 1,
          "can_close": "Ne",
          "backup_strategy": "Manuální záznam na papír"
        }
      },
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Výpadek jednoho zařízení",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 3,
          "can_close": "Ano",
          "backup_strategy": "Použít náhradní zařízení"
        }
      }
    },
    {
      "id": "diag_hod_restart",
      "type": "boolean",
      "question": "Pomohl restart zařízení?",
      "render_if": "hod_symptom == 'Aplikace se nespustí'",
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Dočasná chyba aplikace",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 3,
          "can_close": "Ano",
          "backup_strategy": "Restart zařízení"
        }
      },
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Kritická chyba aplikace HOD",
          "resolver_group": "LOGISTICKE SYSTEMY Support SKODA",
          "impact": 2,
          "can_close": "Ne",
          "backup_strategy": "Použít náhradní zařízení nebo PC stanici"
        }
      }
    },
    {
      "id": "diag_hod_scan_barcode",
      "type": "boolean",
      "question": "Je čárový kód čitelný (nepoškozený)?",
      "render_if": "hod_symptom == 'Chyba při skenování'",
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Poškozený čárový kód",
          "resolver_group": "LOGISTICKE SYSTEMY Support SKODA",
          "impact": 3,
          "can_close": "Ano",
          "backup_strategy": "Ruční zadání kódu"
        }
      },
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Chyba skeneru zařízení",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 2,
          "can_close": "Ano",
          "backup_strategy": "Použít náhradní zařízení"
        }
      }
    },
    {
      "id": "diag_hod_data_sync",
      "type": "boolean",
      "question": "Byla provedena synchronizace dat?",
      "render_if": "hod_symptom == 'Nesprávná data'",
      "on_true": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Chyba datové synchronizace",
          "resolver_group": "LOGISTICKE SYSTEMY Support SKODA",
          "impact": 2,
          "can_close": "Ne",
          "backup_strategy": "Ověřit data v SAP"
        }
      },
      "on_false": {
        "action": "stop",
        "incident_data": {
          "actual_defect": "Nesynchronizovaná data",
          "resolver_group": "AMS NTT Data Service Desk",
          "impact": 3,
          "can_close": "Ano",
          "backup_strategy": "Provést manuální synchronizaci"
        }
      }
    }
  ]
}